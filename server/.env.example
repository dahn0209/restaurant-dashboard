# Copy this file to .env and fill in your live MySQL credentials.
# These names intentionally match the .env you already use for
# createDB_PractI_AhnD.R / loadDB_PractI_AhnD.R so you can reuse the same values.
#
# NOTE: your Aiven-hosted DB requires SSL. Set DB_SSL_CA to the path of your
# ca.pem file (the same one configBusinessLogic_PractI_AhnD.R references).
# DB_PASSWORD is intentionally left blank here — fill it in your own local
# .env only, never in a file you commit or share.

DB_HOST=mysql-practicum1-cs5200-practicum1-ahnd.j.aivencloud.com
DB_PORT=25697
DB_NAME=defaultdb
DB_USER=avnadmin
DB_PASSWORD=
DB_SSL_CA=ca.pem

# Port the API itself listens on
API_PORT=4000

# Comma-separated list of origins allowed to call this API (your React dev server, etc.)
CORS_ORIGIN=http://localhost:5173
